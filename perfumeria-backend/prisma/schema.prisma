generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ENUMS
enum Role {
  ADMIN
  USER
}

enum Genero {
  HOMBRE
  MUJER
  UNISEX
}

enum Concentracion {
  EF
  EDC
  EDT
  EDP
  PARFUM
  ELIXIR
}

enum EstadoCarrito {
  ACTIVO
  COMPLETADO
}

enum EstadoPedido {
  PENDIENTE
  CONFIRMADO
  EN_PREPARACION
  LISTO_RETIRO
  DESPACHADO
  ENTREGADO
  CANCELADO
}

enum EstadoPago {
  PENDIENTE
  APROBADO
  RECHAZADO
  CANCELADO
  REEMBOLSADO
}

enum TipoEntrega {
  ENVIO
  RETIRO
}

enum TipoMetodoPago {
  TARJETA_CREDITO
  TARJETA_DEBITO
  TRANSFERENCIA_BANCARIA
  EFECTIVO
  BILLETERA_VIRTUAL
  OTRO
}

// -----------------------------------------------------------------------------
// MODELOS
// -----------------------------------------------------------------------------

model Usuario {
  id           Int       @id @default(autoincrement())
  nombre       String
  apellido     String
  email        String    @unique
  passwordHash String    @map("password_hash")
  telefono     String?
  role         Role      @default(USER)
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")

  pedidos  Pedido[]
  carritos Carrito[]
  pagos    Pago[]

  @@map("usuarios")
}

model Marca {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  paisOrigen  String?   @map("pais_origen")
  activo      Boolean   @default(true)
  logoUrl     String?   @map("logo_url")

  perfumes Perfume[]

  @@map("marcas")
}

model Perfume {
  id            Int           @id @default(autoincrement())
  marcaId       Int           @map("marca_id")
  categoriaId   Int           @map("categoria_id")
  nombre        String
  descripcion   String?
  concentracion Concentracion?
  genero        Genero
  tipo          String?
  activo        Boolean       @default(true)
  imagenUrl     String?       @map("imagen_url")
  slug          String        @unique
  createdAt     DateTime      @default(now()) @map("created_at")

  marca     Marca              @relation(fields: [marcaId], references: [id])
  categoria Categoria         @relation(fields: [categoriaId], references: [id])
  variantes VariantePerfume[]

  @@map("perfumes")
}

model Categoria {
  id          Int       @id @default(autoincrement())
  nombre      String
  descripcion String?
  slug        String    @unique

  perfumes Perfume[]

  @@map("categorias")
}

model VariantePerfume {
  id        Int     @id @default(autoincrement())
  perfumeId Int     @map("perfume_id")
  volumen   Int
  precio    Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
  sku       String  @unique
  activo    Boolean @default(true)

  perfume      Perfume       @relation(fields: [perfumeId], references: [id])
  itemsCarrito ItemCarrito[]
  itemsPedido  ItemPedido[]

  @@map("variantes_perfume")
}

model Carrito {
  id        Int           @id @default(autoincrement())
  usuarioId Int           @map("usuario_id")
  estado    EstadoCarrito @default(ACTIVO)
  creadoAt  DateTime      @default(now()) @map("creado_at")

  usuario Usuario     @relation(fields: [usuarioId], references: [id])
  items   ItemCarrito[]

  @@map("carritos")
}

model ItemCarrito {
  carritoId      Int     @map("carrito_id")
  varianteId     Int     @map("variante_id")
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2) @map("precio_unitario")

  carrito  Carrito         @relation(fields: [carritoId], references: [id])
  variante VariantePerfume @relation(fields: [varianteId], references: [id])

  @@id([carritoId, varianteId])
  @@map("items_carrito")
}

model Pedido {
  id             Int          @id @default(autoincrement())
  usuarioId      Int          @map("usuario_id")
  nroPedido      String       @unique @map("nro_pedido")
  tipoEntrega    TipoEntrega  @map("tipo_entrega")
  subtotal       Decimal      @db.Decimal(10, 2)
  costoEnvio     Decimal      @db.Decimal(10, 2) @default(0) @map("costo_envio")
  total          Decimal      @db.Decimal(10, 2)
  estado         EstadoPedido @default(PENDIENTE)
  fechaCreacion  DateTime     @default(now()) @map("fecha_creacion")
  observaciones  String?      @map("observaciones")

  telefonoContacto String?    @map("telefono_contacto")
  direccionEnvio   String?    @map("direccion_envio")
  ciudadEnvio      String?    @map("ciudad_envio")
  provinciaEnvio   String?    @map("provincia_envio")
  codigoPostalEnvio String?   @map("codigo_postal_envio")

  usuario   Usuario     @relation(fields: [usuarioId], references: [id])
  items     ItemPedido[]
  pagos     Pago[]

  @@map("pedidos")
}

model ItemPedido {
  pedidoId       Int     @map("pedido_id")
  varianteId     Int     @map("variante_id")
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2) @map("precio_unitario")

  pedido   Pedido          @relation(fields: [pedidoId], references: [id])
  variante VariantePerfume @relation(fields: [varianteId], references: [id])

  @@id([pedidoId, varianteId])
  @@map("items_pedido")
}

model MetodoPago {
  id     Int            @id @default(autoincrement())
  nombre String         @unique
  tipo   TipoMetodoPago
  activo Boolean        @default(true)

  pagos Pago[]

  @@map("metodos_pago")
}

model Pago {
  id                 Int        @id @default(autoincrement())
  pedidoId           Int        @map("pedido_id")
  metodoPagoId       Int        @map("metodo_pago_id")
  usuarioId          Int        @map("usuario_id")
  cuotas             Int        @default(1)
  monto              Decimal    @db.Decimal(10, 2)
  moneda             String     @default("ARS")
  estado             EstadoPago @default(PENDIENTE)
  externalId         String?    @map("external_id")
  externalStatus     String?    @map("external_status")
  paymentType        String?    @map("payment_type")
  montoReembolso     Decimal?   @db.Decimal(10, 2) @map("monto_reembolso")
  fechaReembolso     DateTime?  @map("fecha_reembolso")
  fechaCreacion      DateTime   @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime   @updatedAt @map("fecha_actualizacion")

  pedido     Pedido     @relation(fields: [pedidoId], references: [id])
  metodoPago MetodoPago @relation(fields: [metodoPagoId], references: [id])
  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  eventos    PagoEvento[]

  @@map("pagos")
}

model PagoEvento {
  id             Int        @id @default(autoincrement())
  pagoId         Int        @map("pago_id")
  estadoAnterior EstadoPago? @map("estado_anterior")
  estadoNuevo    EstadoPago @map("estado_nuevo")
  origen         String
  payload        Json?
  fecha          DateTime   @default(now())

  pago Pago @relation(fields: [pagoId], references: [id])

  @@map("pagos_eventos")
}