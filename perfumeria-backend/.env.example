# SERVER
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# DATABASE
# Reemplazar valores con tus credenciales de Postgres
DATABASE_URL="postgresql://user:password@localhost:5432/perfumeria_db?schema=public"

# AUTH
# Generar un string seguro de +32 caracteres
JWT_SECRET=escribir_aqui_un_secreto_largo_y_seguro
JWT_EXPIRES_IN=8h

# BUSINESS LOGIC
COSTO_ENVIO_DEFAULT=5000

